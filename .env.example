# Copy this file to .env and fill in your values
# .env is gitignored — never commit your real tokens!

TELEGRAM_BOT_TOKEN=your_token_here
TELEGRAM_CHAT_ID=your_chat_id_here
MIN_TRADE_SIZE=500

# Optional — Discord alerts
# DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/...

# Optional — filters (comma-separated; empty = all markets)
# MARKET_FILTER=Fed rate,Trump
# CATEGORY_FILTER=Politics,Crypto

# Optional — seconds between alerts per market (0 = off)
# ALERT_COOLDOWN=300

# Optional — Postgres (Railway injects this automatically).
# Defaults to local SQLite (whales.db) when unset.
# DATABASE_URL=postgresql://user:pass@host:5432/dbname

# Required only for whale_of_day.py (daily auto-post script)
# WHALE_CHANNEL_ID=your_channel_id_here
